# Neon PostgreSQL Database URL
# Get this from your Neon project dashboard: https://console.neon.tech
DATABASE_URL=postgresql://username:password@ep-xxxx.us-east-2.aws.neon.tech/neondb?sslmode=require

# JWT Secret - change this to a strong random string in production
JWT_SECRET=your-super-secret-jwt-key-change-in-production

# Server port
PORT=5000

# Client URL (for CORS)
CLIENT_URL=http://localhost:5173
